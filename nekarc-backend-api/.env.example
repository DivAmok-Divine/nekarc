APP_NAME=nekarc
ENV=development

# Auth — set SECRET_KEY to a long random string in production
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database & storage
DATABASE_URL=sqlite:///./data/app.db
UPLOAD_DIR=./data/uploads

# CORS / URLs
CORS_ORIGINS=http://localhost:2222
FRONTEND_URL=http://localhost:2222

# Optional SMTP — leave blank in dev (reset links print to the backend console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@nekarc.local

# Gemini (optional) — enables importing a building plan (image/PDF) into floors & rooms.
# Free key from https://aistudio.google.com/apikey  (DXF import works without this.)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
